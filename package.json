{
  "name": "teste-ambevtech",
  "version": "1.0.0",
  "description": "Projeto de testes E2E com Cypress para o processo seletivo AmbevTech",
  "scripts": {
    "cy:open": "cypress open",
    "cy:run": "cypress run",
    "cy:run:frontend": "cypress run --spec 'cypress/e2e/frontend/**/*.cy.js'",
    "cy:run:api": "cypress run --spec 'cypress/e2e/api/**/*.cy.js'",
    "lint": "eslint cypress/**/*.js",
    "lint:fix": "eslint cypress/**/*.js --fix"
  },
  "devDependencies": {
    "@cypress/grep": "^3.1.5",
    "@faker-js/faker": "^10.5.0",
    "cypress": "^13.17.0",
    "eslint": "^10.6.0",
    "eslint-plugin-cypress": "^3.6.0",
    "globals": "^17.7.0"
  }
}
